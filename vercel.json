{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/",          "dest": "/index.html" },
    { "src": "/sobre",     "dest": "/sobre.html" },
    { "src": "/servicos",  "dest": "/servicos.html" },
    { "src": "/contato",   "dest": "/contato.html" },
    { "src": "/news",      "dest": "/news.html" },
    { "src": "/ferramenta","dest": "/ferramenta.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ]
}
